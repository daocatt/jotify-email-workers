{
  "name": "jotify-email-workers",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-24",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jotify_email_db",
      "database_id": "YOUR_D1_DATABASE_ID_HERE"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENT_BUCKET",
      "bucket_name": "YOUR_R2_BUCKET_NAME_HERE"
    }
  ],
  "routes": [
    {
      "pattern": "your-custom-domain.com",
      "custom_domain": true
    }
  ],
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "queues": {
    "producers": [
      {
        "binding": "RETRY_QUEUE",
        "queue": "jotify-email-retry"
      }
    ],
    "consumers": [
      {
        "queue": "jotify-email-retry",
        "max_batch_size": 10,
        "max_retries": 17,
        "dead_letter_queue": "jotify-email-dlq"
      },
      {
        "queue": "jotify-email-dlq",
        "max_retries": 0
      }
    ]
  }
}
